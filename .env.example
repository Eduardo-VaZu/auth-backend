PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000
TRUST_PROXY=false
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/auth_backend
DB_POOL_MAX=10
DB_POOL_IDLE_TIMEOUT=10000
DB_POOL_CONNECTION_TIMEOUT=5000
REDIS_URL=redis://localhost:6379
ACCESS_TOKEN_SECRET=replace-with-a-32-character-access-secret
REFRESH_TOKEN_SECRET=replace-with-a-32-character-refresh-secret
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d
COOKIE_SECRET=replace-with-a-32-character-cookie-secret
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
MAX_SESSIONS_PER_USER=5
SHUTDOWN_TIMEOUT_MS=10000
