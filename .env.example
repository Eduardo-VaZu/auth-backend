# Server Configuration
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000
TRUST_PROXY=false

# Database Configuration (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/auth_backend
DB_POOL_MAX=10
DB_POOL_IDLE_TIMEOUT=10000
DB_POOL_CONNECTION_TIMEOUT=5000

# Redis Configuration
REDIS_URL=redis://localhost:6379

# JWT Secrets (Must be 32 characters in production)
ACCESS_TOKEN_SECRET=replace-with-a-32-character-access-secret
REFRESH_TOKEN_SECRET=replace-with-a-32-character-refresh-secret
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# Cookie Configuration (Secret must be 32 characters)
COOKIE_SECRET=replace-with-a-32-character-cookie-secret
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax

# Session Management
MAX_SESSIONS_PER_USER=5
EXPIRED_SESSION_RETENTION_SECONDS=0

# Graceful Shutdown
SHUTDOWN_TIMEOUT_MS=10000

# Email Delivery (e.g., using Brevo)
EMAIL_DELIVERY_MODE=preview
BREVO_API_KEY=xkeysib-1234567890abcdef1234567890abcdef-abcdef1234567890
BREVO_SENDER_EMAIL=noreply@example.com
BREVO_SENDER_NAME=Auth Backend
