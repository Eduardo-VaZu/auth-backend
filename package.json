{
  "name": "auth-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Robust authentication backend built with Express, TypeScript, Drizzle, Redis and Inversify.",
  "type": "module",
  "packageManager": "npm@10.9.3",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "nodemon --config nodemon.json",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main/server.js",
    "type:check": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "npm run build && drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate:legacy-credentials": "tsx src/infrastructure/db/migrations/data-migration.ts",
    "db:seed:roles": "tsx src/infrastructure/db/migrations/seed-roles.ts",
    "db:studio": "drizzle-kit studio",
    "hooks:install": "node scripts/install-git-hooks.mjs",
    "pr:check": "npm run type:check && npm run lint && npm run test:ci",
    "test": "vitest run",
    "test:unit": "vitest run --project unit --passWithNoTests",
    "test:integration": "vitest run --project integration --passWithNoTests",
    "test:unit:ci": "vitest run --project unit --passWithNoTests",
    "test:integration:ci": "vitest run --project integration --passWithNoTests",
    "test:ci": "npm run test:unit:ci && npm run test:integration:ci",
    "test:watch": "vitest",
    "test:coverage": "vitest run --project unit --coverage",
    "docker:build": "docker build -t auth-backend .",
    "docker:up:d": "docker compose up -d postgres redis",
    "docker:up:full": "docker compose --profile fullstack up -d --build",
    "docker:down": "docker compose down --volumes --remove-orphans",
    "dev:local": "npm run docker:up:d && npm run dev"
  },
  "keywords": [
    "auth",
    "backend",
    "express",
    "typescript",
    "drizzle",
    "redis",
    "inversify"
  ],
  "dependencies": {
    "argon2": "^0.41.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^1.0.0-beta.21",
    "express": "^5.1.0",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "inversify": "^7.6.0",
    "jose": "^5.9.6",
    "node-cron": "^4.2.1",
    "pg": "^8.13.1",
    "pino": "^9.5.0",
    "rate-limit-redis": "^4.2.2",
    "redis": "^4.7.0",
    "reflect-metadata": "^0.2.2",
    "uuid": "^11.0.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^11.14.0",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "@vitest/coverage-v8": "^4.1.5",
    "drizzle-kit": "^1.0.0-beta.21",
    "eslint": "^8.57.1",
    "nodemon": "^3.1.7",
    "pino-pretty": "^13.0.0",
    "prettier": "^3.4.2",
    "supertest": "^7.2.2",
    "testcontainers": "^11.14.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.5"
  }
}
